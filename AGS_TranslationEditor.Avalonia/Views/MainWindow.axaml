<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:AGS_TranslationEditor.ViewModels"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="900" d:DesignHeight="600"
        x:Class="AGS_TranslationEditor.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Title="{Binding WindowTitle}"
        Width="900" Height="600"
        MinWidth="600" MinHeight="400">

  <DockPanel>

    <!-- Menu Bar -->
    <Menu DockPanel.Dock="Top">
      <MenuItem Header="_File">
        <MenuItem Header="_Open..." Name="MenuOpen" />
        <MenuItem Header="_Save" Name="MenuSave" />
        <MenuItem Header="Save _As..." Name="MenuSaveAs" />
        <Separator />
        <MenuItem Header="_Export">
          <MenuItem Header="Export as CSV..." Name="MenuExportCSV" />
          <MenuItem Header="Export as PO..." Name="MenuExportPO" />
        </MenuItem>
        <Separator />
        <MenuItem Header="E_xit" Name="MenuExit" />
      </MenuItem>
      <MenuItem Header="_Tools">
        <MenuItem Header="_Extract Script..." Name="MenuExtractScript" />
        <MenuItem Header="_Game Info..." Name="MenuGameInfo" />
        <MenuItem Header="Create _TRA File..." Name="MenuCreateTRA" />
      </MenuItem>
      <MenuItem Header="_Help">
        <MenuItem Header="_About" Name="MenuAbout" />
      </MenuItem>
    </Menu>

    <!-- Tool Bar -->
    <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Spacing="4" Margin="4,2" Background="#E8E8E8">
      <Button Name="BtnOpen" ToolTip.Tip="Open File">Open</Button>
      <Button Name="BtnSave" ToolTip.Tip="Save File">Save</Button>
      <Separator Width="8" />
      <TextBox Name="TxtSearch" Width="150" Watermark="Search..." />
      <Button Name="BtnFind" ToolTip.Tip="Find">Find</Button>
      <Button Name="BtnFindPrev" ToolTip.Tip="Previous">◀</Button>
      <Button Name="BtnFindNext" ToolTip.Tip="Next">▶</Button>
      <Separator Width="8" />
      <ToggleButton Name="BtnFilterUntranslated" ToolTip.Tip="Show only untranslated entries">⚑ Untranslated only</ToggleButton>
      <Button Name="BtnNextUntranslated" ToolTip.Tip="Jump to next untranslated entry">↓ Next untranslated</Button>
    </StackPanel>

    <!-- Status Bar -->
    <Grid DockPanel.Dock="Bottom" ColumnDefinitions="*,Auto,120" Height="24" Background="#F0F0F0">
      <TextBlock Grid.Column="0" Text="{Binding FileStatusText}" VerticalAlignment="Center" Margin="4,0" />
      <TextBlock Grid.Column="1" Text="{Binding EntriesCountText}" VerticalAlignment="Center" Margin="4,0" />
      <ProgressBar Grid.Column="2" Value="{Binding ProgressValue}" Minimum="0" Maximum="100" Height="14" Margin="4,4" />
    </Grid>

    <!-- Main Content -->
    <Grid RowDefinitions="*,4,80">

      <!-- Translation DataGrid -->
      <DataGrid Grid.Row="0"
                Name="DgvTranslation"
                ItemsSource="{Binding DisplayedEntries}"
                SelectedItem="{Binding SelectedEntry}"
                AutoGenerateColumns="False"
                CanUserSortColumns="True"
                GridLinesVisibility="Horizontal">
        <DataGrid.Styles>
          <Style Selector="DataGridRow">
            <Setter Property="Background" Value="Transparent" />
          </Style>
          <Style Selector="DataGridRow[Tag=untranslated]">
            <Setter Property="Background" Value="#FFF3CD" />
          </Style>
        </DataGrid.Styles>
        <DataGrid.Columns>
          <DataGridTextColumn Header="Source (Original)" Binding="{Binding Key}" Width="*" IsReadOnly="True" />
          <DataGridTextColumn Header="Translation" Binding="{Binding Value}" Width="*" />
        </DataGrid.Columns>
      </DataGrid>

      <GridSplitter Grid.Row="1" ResizeDirection="Rows" />

      <!-- Edit Area -->
      <Grid Grid.Row="2" ColumnDefinitions="*,4,*" Margin="4">
        <DockPanel Grid.Column="0">
          <TextBlock DockPanel.Dock="Top" Text="Source:" FontWeight="Bold" Margin="0,0,0,2" />
          <TextBox Text="{Binding SourceText}" IsReadOnly="True" TextWrapping="Wrap" AcceptsReturn="True" />
        </DockPanel>
        <GridSplitter Grid.Column="1" ResizeDirection="Columns" />
        <DockPanel Grid.Column="2">
          <TextBlock DockPanel.Dock="Top" Text="Translation:" FontWeight="Bold" Margin="0,0,0,2" />
          <TextBox Text="{Binding TranslationText}" TextWrapping="Wrap" AcceptsReturn="True" />
        </DockPanel>
      </Grid>

    </Grid>

  </DockPanel>
</Window>

